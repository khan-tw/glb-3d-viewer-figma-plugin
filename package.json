{
  "name": "glb-3d-viewer-figma-plugin",
  "version": "1.0.0",
  "private": true,
  "description": "A Figma plugin for previewing GLB files with adjustable camera FOV and light position, built with React and WebGL.",
  "scripts": {
    "build": "npm run build:ui && npm run build:code",
    "build:ui": "vite build",
    "build:code": "esbuild src/code.ts --bundle --outfile=dist/code.js --format=iife --target=es2017",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.171.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.106.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.171.0",
    "esbuild": "^0.28.1",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
